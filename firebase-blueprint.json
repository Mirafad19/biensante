{
  "entities": {
    "User": {
      "title": "User",
      "description": "A patient or staff member in the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "admin", "doctor"] },
        "patientId": { "type": "string", "description": "Hospital specific patient ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "firstName", "lastName", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A medical appointment request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientUid": { "type": "string" },
        "patientName": { "type": "string" },
        "patientEmail": { "type": "string", "format": "email" },
        "patientPhone": { "type": "string" },
        "specialty": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientName", "patientEmail", "specialty", "date", "status", "createdAt"]
    },
    "LabResult": {
      "title": "Lab Result",
      "description": "A medical laboratory test result",
      "type": "object",
      "properties": {
        "patientUid": { "type": "string" },
        "testName": { "type": "string" },
        "category": { "type": "string" },
        "value": { "type": "string" },
        "unit": { "type": "string" },
        "referenceRange": { "type": "string" },
        "status": { "type": "string", "enum": ["normal", "abnormal", "critical"] },
        "doctorNotes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "testName", "value", "status", "date"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "A medication prescription",
      "type": "object",
      "properties": {
        "patientUid": { "type": "string" },
        "medicationName": { "type": "string" },
        "dosage": { "type": "string" },
        "frequency": { "type": "string" },
        "duration": { "type": "string" },
        "doctorName": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "completed", "discontinued"] }
      },
      "required": ["patientUid", "medicationName", "dosage", "status"]
    },
    "Vital": {
      "title": "Vital Sign",
      "description": "A recorded health vital sign",
      "type": "object",
      "properties": {
        "patientUid": { "type": "string" },
        "type": { "type": "string", "enum": ["BP", "Weight", "HeartRate", "Temp", "Oxygen"] },
        "value": { "type": "string" },
        "unit": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "type", "value", "date"]
    },
    "Message": {
      "title": "Message",
      "description": "A secure message between patient and care team",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "attachments": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["senderId", "receiverId", "content", "timestamp"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A billing invoice for medical services",
      "type": "object",
      "properties": {
        "patientUid": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid", "pending", "overdue"] },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientUid", "amount", "status", "dueDate", "createdAt"]
    },
    "TelehealthSession": {
      "title": "Telehealth Session",
      "description": "A virtual medical consultation session",
      "type": "object",
      "properties": {
        "patientUid": { "type": "string" },
        "doctorUid": { "type": "string" },
        "doctorName": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "active", "completed", "cancelled"] },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "meetingLink": { "type": "string" },
        "roomName": { "type": "string" }
      },
      "required": ["patientUid", "doctorName", "status", "startTime", "roomName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records"
    },
    "/lab_results/{resultId}": {
      "schema": "LabResult",
      "description": "Patient lab results"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Patient prescriptions"
    },
    "/vitals/{vitalId}": {
      "schema": "Vital",
      "description": "Patient vital signs tracking"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Secure patient-doctor messages"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Billing and payment records"
    },
    "/telehealth_sessions/{sessionId}": {
      "schema": "TelehealthSession",
      "description": "Virtual consultation sessions"
    }
  }
}
